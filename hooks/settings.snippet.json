{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/skills/trail/scripts/phase_check.py guard-tag"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/skills/trail/scripts/trace_status.py ."
          }
        ]
      }
    ]
  }
}
